# HR Analytics Platform — Environment Variables
# Copy this file to .env and fill in values

# App Settings
APP_ENV=production
APP_PORT=8501

# Data Paths (override config.yaml)
RAW_DATA_PATH=data/raw/HR_Employee_Attrition.csv
PROCESSED_DATA_PATH=data/processed/hr_enriched.csv
MODELS_DIR=models/

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hr_analytics.log

# Model Settings
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5

# Optional: AWS S3 for model storage
# AWS_BUCKET=hr-analytics-models
# AWS_REGION=ap-south-1
